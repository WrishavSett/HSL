{
    "prompt": "Extract all data from this TAX INVOICE document image and return it as a valid JSON object that strictly conforms to the provided schema.",

    "fields_of_interest": {
        "company_name":           "letter_head.company_name",
        "invoice_no":             "invoice_details.invoice_no",
        "order_no":               "line_items[0].order_ref",
        "total_amount_before_tax": "summary.invoice_value"
    },

    "response_schema": {
        "type": "object",
        "properties": {

            "letter_head": {
                "type": "object",
                "properties": {
                    "company_name": { "type": "string" },
                    "address":      { "type": "string" },
                    "phone":        { "type": "string" },
                    "email":        { "type": "string" },
                    "gstin":        { "type": "string" }
                },
                "required": [
                    "company_name", "address", "phone", "email", "gstin"
                ]
            },

            "document_type_labels": {
                "type": "object",
                "properties": {
                    "title":              { "type": "string" },
                    "recipient_copy_tag": { "type": "string" }
                },
                "required": ["title", "recipient_copy_tag"]
            },

            "customer_details": {
                "type": "object",
                "properties": {
                    "name":            { "type": "string" },
                    "address":         { "type": "string" },
                    "gstin":           { "type": "string" },
                    "place_of_supply": { "type": "string" },
                    "reverse_charge":  { "type": "string" }
                },
                "required": [
                    "name", "address", "gstin", "place_of_supply", "reverse_charge"
                ]
            },

            "invoice_details": {
                "type": "object",
                "properties": {
                    "invoice_no": { "type": "string" },
                    "date":       { "type": "string" }
                },
                "required": ["invoice_no", "date"]
            },

            "line_items": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "properties": {
                        "serial_no":     { "type": "string" },
                        "description":   { "type": "string" },
                        "order_ref":     { "type": "string" },
                        "line_date":     { "type": "string" },
                        "sac_code":      { "type": "string" },
                        "quantity":      { "type": "string" },
                        "unit":          { "type": "string" },
                        "rate":          { "type": "string" },
                        "total_value":   { "type": "string" }
                    },
                    "required": [
                        "serial_no", "description", "order_ref", "line_date",
                        "sac_code", "quantity", "unit", "rate", "total_value"
                    ]
                }
            },

            "items_total": { "type": "string" },

            "amount_in_words": { "type": "string" },

            "tax_breakup_table": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "properties": {
                        "serial_no":  { "type": "string" },
                        "cgst_rate":   { "type": "string" },
                        "cgst_amount": { "type": "string" },
                        "sgst_rate":   { "type": "string" },
                        "sgst_amount": { "type": "string" },
                        "igst_rate":   { "type": "string" },
                        "igst_amount": { "type": "string" }
                    },
                    "required": [
                        "serial_no", "cgst_rate", "cgst_amount",
                        "sgst_rate", "sgst_amount", "igst_rate", "igst_amount"
                    ]
                }
            },

            "tax_breakup_totals": {
                "type": "object",
                "properties": {
                    "total_cgst": { "type": "string" },
                    "total_sgst": { "type": "string" },
                    "total_igst": { "type": "string" }
                },
                "required": ["total_cgst", "total_sgst", "total_igst"]
            },

            "note": { "type": "string" },

            "remarks": { "type": "string" },

            "bank_details": {
                "type": "object",
                "properties": {
                    "account_number": { "type": "string" },
                    "ifsc":           { "type": "string" },
                    "bank_name":      { "type": "string" },
                    "branch":         { "type": "string" }
                },
                "required": ["account_number", "ifsc", "bank_name", "branch"]
            },

            "terms_and_conditions": { "type": "string" },

            "summary": {
                "type": "object",
                "properties": {
                    "invoice_value": { "type": "string" },
                    "total_cgst":    { "type": "string" },
                    "total_sgst":    { "type": "string" },
                    "total_igst":    { "type": "string" },
                    "total_gst":     { "type": "string" },
                    "grand_total":   { "type": "string" }
                },
                "required": [
                    "invoice_value", "total_cgst", "total_sgst",
                    "total_igst", "total_gst", "grand_total"
                ]
            },

            "closing_message": { "type": "string" },

            "authorised_signatory": {
                "type": "object",
                "properties": {
                    "signatory_label": { "type": "string" },
                    "company_seal_present": { "type": "boolean" }
                },
                "required": ["signatory_label", "company_seal_present"]
            }

        },
        "required": [
            "letter_head",
            "document_type_labels",
            "customer_details",
            "invoice_details",
            "line_items",
            "items_total",
            "amount_in_words",
            "tax_breakup_table",
            "tax_breakup_totals",
            "note",
            "remarks",
            "bank_details",
            "terms_and_conditions",
            "summary",
            "authorised_signatory"
        ]
    }
}